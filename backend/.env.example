# Database (SQLite for local dev, PostgreSQL for production)
DATABASE_URL=sqlite:///./bookings.db
# DATABASE_URL=postgresql://user:pass@host:5432/shuttle_booking

# Straumur payment gateway (https://portal.straumur.is)
STRAUMUR_API_KEY=
STRAUMUR_TERMINAL_ID=
STRAUMUR_HMAC_KEY=
# Use staging URL for testing; leave empty for production
# STRAUMUR_API_BASE_URL=https://checkout-api.staging.straumur.is/api/v1

# Resend email (get from resend.com/api-keys)
RESEND_API_KEY=
EMAIL_FROM=bookings@flyershotel.is

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Pricing
PRICE_PER_PASSENGER_ISK=2200

# Admin dashboard (password for /admin access)
ADMIN_PASSWORD=
